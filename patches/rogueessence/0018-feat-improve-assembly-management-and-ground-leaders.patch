@@ -0,0 +1,13 @@
+namespace RogueEssence.Menu
+{
+    public class AssemblyMenuOptions
+    {
+        public string SearchLabel { get; set; } = "Search";
+        public string ClearSearchLabel { get; set; } = "Clear search";
+        public string FavoritesOnlyLabel { get; set; } = "Favorites only";
+        public string ShowAllLabel { get; set; } = "Show all";
+        public string SearchTitle { get; set; } = "Search team";
+        public string ReleaseRewardMessage { get; set; } = "";
+        public int ReleaseReward { get; set; }
+    }
+}
diff --git a/RogueEssence/Menu/Team/AssemblySearchMenu.cs b/RogueEssence/Menu/Team/AssemblySearchMenu.cs
new file mode 100644
index 00000000..38c97906
--- /dev/null
+++ b/RogueEssence/Menu/Team/AssemblySearchMenu.cs
@@ -0,0 +1,36 @@
+using System;
+
+namespace RogueEssence.Menu
+{
+    public class AssemblySearchMenu : TextInputMenu
+    {
+        public const int MAX_LENGTH = 120;
+        public override int MaxLength => MAX_LENGTH;
+
+        private readonly OnChooseText chooseTextAction;
+        private readonly Action cancelAction;
+
+        public AssemblySearchMenu(string title, string defaultValue,
+            OnChooseText action, Action cancelAction)
+        {
+            Label = "ASSEMBLY_SEARCH_MENU";
+            chooseTextAction = action;
+            this.cancelAction = cancelAction;
+            Initialize(title, "", 256, defaultValue ?? "");
+        }
+
+        protected override void Confirmed()
+        {
+            GameManager.Instance.SE("Menu/Confirm");
+            MenuManager.Instance.RemoveMenu();
+            chooseTextAction(Text.Text.Trim());
+        }
+
+        protected override void Canceled()
+        {
+            GameManager.Instance.SE("Menu/Cancel");
+            MenuManager.Instance.RemoveMenu();
+            cancelAction();
+        }
+    }
+}
