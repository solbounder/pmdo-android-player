+        /// <summary>
+        /// Archives the current Quest save boundary before an explicitly
+        /// confirmed New Game.  Base-game and other Quest namespaces use
+        /// different ModSavePath roots and are never touched.
+        /// </summary>
+        public void ArchiveSaveForNewGame()
+        {
+            if (!PathMod.Quest.IsValid())
+                throw new InvalidOperationException("New Game archival is only valid inside a Quest save namespace.");
+
+            string savePath = PathMod.ModSavePath(SAVE_PATH, SAVE_FILE_PATH);
+            string backupPath = PathMod.ModSavePath(SAVE_PATH, SAVE_BACKUP_FILE_PATH);
+            string quicksavePath = PathMod.ModSavePath(SAVE_PATH, QUICKSAVE_FILE_PATH);
+            string pendingPath = PathMod.ModSavePath(SAVE_PATH, SAVE_PENDING_FILE_PATH);
+            string writePath = PathMod.ModSavePath(SAVE_PATH, SAVE_WRITE_FILE_PATH);
+
+            void archive(string source, string destination)
+            {
+                if (File.Exists(source))
+                    File.Copy(source, destination, true);
+            }
+
+            // Copy every recoverable source first.  Nothing is removed until
+            // all requested archives have succeeded.
+            archive(savePath, PathMod.ModSavePath(SAVE_PATH, SAVE_NEW_GAME_BACKUP_FILE_PATH));
+            archive(backupPath, PathMod.ModSavePath(SAVE_PATH, SAVE_BACKUP_NEW_GAME_BACKUP_FILE_PATH));
+            archive(quicksavePath, PathMod.ModSavePath(SAVE_PATH, QUICKSAVE_NEW_GAME_BACKUP_FILE_PATH));
+            archive(pendingPath, pendingPath + ".new-game.bak");
+            archive(writePath, writePath + ".new-game.bak");
+
+            if (File.Exists(quicksavePath))
+                File.Delete(quicksavePath);
+            if (File.Exists(pendingPath))
+                File.Delete(pendingPath);
+            if (File.Exists(writePath))
+                File.Delete(writePath);
+            if (File.Exists(backupPath))
+                File.Delete(backupPath);
+            if (File.Exists(savePath))
+                File.Delete(savePath);
+        }
+
         /// <summary>
         /// Deletes replays from the replay folder corresponding to the current mod.
         /// </summary>
