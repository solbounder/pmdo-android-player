@@ -1,5 +1,6 @@
 ﻿using System;
 using System.Collections.Generic;
+using Microsoft.Xna.Framework.Input;
 using RogueElements;
 using RogueEssence.Content;
 
@@ -81,6 +82,54 @@ namespace RogueEssence.Menu
 
         protected virtual void MultiSelectChanged() { }
 
+        protected virtual IEnumerable<IChoosable> GetMultiSelectChoices()
+        {
+            return Choices;
+        }
+
+        protected bool SelectAllEnabledChoices()
+        {
+            RefreshSelectedTotal();
+            bool changed = false;
+            foreach (IChoosable choice in GetMultiSelectChoices())
+            {
+                MenuChoice menuChoice = choice as MenuChoice;
+                if (selectedTotal >= MultiSelect.Max - 1)
+                    break;
+                if (MultiSelectInput.CanSelectChoice(menuChoice != null && menuChoice.Enabled,
+                    menuChoice != null && menuChoice.Selected, selectedTotal, MultiSelect.Max))
+                {
+                    menuChoice.SilentSelect(true);
+                    selectedTotal++;
+                    changed = true;
+                }
+            }
+
+            GameManager.Instance.SE(changed ? "Menu/Toggle" : "Menu/Cancel");
+            if (changed)
+                MultiSelectChanged();
+            return changed;
+        }
+
+        private void RefreshSelectedTotal()
+        {
+            selectedTotal = 0;
+            foreach (IChoosable choice in GetMultiSelectChoices())
+            {
+                if (choice.Selected)
+                    selectedTotal++;
+            }
+        }
+
+        private static bool MultiSelectPressed(InputManager input)
+        {
+            return MultiSelectInput.ShoulderPressed(input.JustPressed(FrameInput.InputType.SelectItems),
+                input.BaseButtonPressed(Buttons.LeftShoulder),
+                input.BaseButtonPressed(Buttons.RightShoulder),
+                input.BaseButtonPressed(Buttons.LeftTrigger),
+                input.BaseButtonPressed(Buttons.RightTrigger));
+        }
+
         public override void Update(InputManager input)
         {
             UpdateMouse(input);
