+        private static int GetStorageUnits()
+        {
+            int count = DataManager.Instance.Save.ActiveTeam.BoxStorage.Count;
+            foreach (string id in DataManager.Instance.Save.ActiveTeam.Storage.Keys)
+                count += DataManager.Instance.Save.ActiveTeam.Storage[id];
+            return count;
+        }
+
+        private int GetSelectionUnits()
+        {
+            int count = 0;
+            foreach (InvSlot slot in selections)
+            {
+                InvItem item = slot.IsEquipped ?
+                    DataManager.Instance.Save.ActiveTeam.Players[slot.Slot].EquippedItem :
+                    DataManager.Instance.Save.ActiveTeam.GetInv(slot.Slot);
+                ItemData entry = DataManager.Instance.GetItem(item.ID);
+                count += entry.UsageType == ItemData.UseType.Box ? 1 :
+                    (entry.MaxStack > 1 ? item.Amount : 1);
+            }
+            return count;
+        }
+
