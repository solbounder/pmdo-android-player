diff --git a/RogueEssence/Data/SaveTransaction.cs b/RogueEssence/Data/SaveTransaction.cs
new file mode 100644
index 00000000..0e1289b3
--- /dev/null
+++ b/RogueEssence/Data/SaveTransaction.cs
@@ -0,0 +1,107 @@
+using System;
+using System.IO;
+
+namespace RogueEssence.Data
+{
+    internal enum PreparedSaveRecovery
+    {
+        None,
+        DiscardedForQuicksave,
+        Committed,
+        Rejected
+    }
+
+    /// <summary>
+    /// Small, filesystem-only save transaction helper.  Prepared adventure
+    /// saves use the quicksave as their commit journal: while the quicksave
+    /// exists the adventure can still be resumed, and after it has been
+    /// archived the prepared main save is the authoritative result.
+    /// </summary>
+    internal static class SaveTransaction
+    {
+        internal static void Prepare(string preparedPath, Action<Stream> write)
+        {
+            string tempPath = preparedPath + ".tmp";
+            DeleteIfExists(tempPath);
+
+            string directory = Path.GetDirectoryName(preparedPath);
+            if (!String.IsNullOrEmpty(directory))
+                Directory.CreateDirectory(directory);
+
+            using (FileStream stream = new FileStream(tempPath, FileMode.CreateNew,
+                FileAccess.Write, FileShare.None, 4096, FileOptions.WriteThrough))
+            {
+                write(stream);
+                stream.Flush(true);
+            }
+
+            // A prepared save is not authoritative yet.  Replacing an older
+            // prepared file does not need a backup because the quicksave is
+            // still present during this phase.
+            DeleteIfExists(preparedPath);
+            File.Move(tempPath, preparedPath);
+        }
+
+        internal static void AtomicWrite(string destinationPath, string backupPath,
+            string stagingPath, Action<Stream> write)
+        {
+            Prepare(stagingPath, write);
+            Commit(stagingPath, destinationPath, backupPath);
+        }
+
+        internal static void Commit(string preparedPath, string destinationPath,
+            string backupPath)
+        {
+            if (!File.Exists(preparedPath))
+                throw new FileNotFoundException("Prepared save is missing.", preparedPath);
+
+            if (File.Exists(destinationPath))
+            {
+                DeleteIfExists(backupPath);
+                File.Replace(preparedPath, destinationPath, backupPath, true);
+            }
+            else
+                File.Move(preparedPath, destinationPath);
+        }
+
+        internal static PreparedSaveRecovery Recover(string preparedPath,
+            string destinationPath, string backupPath, string quicksavePath,
+            Func<string, bool> validate)
+        {
+            DeleteIfExists(preparedPath + ".tmp");
+            if (!File.Exists(preparedPath))
+                return PreparedSaveRecovery.None;
+
+            if (File.Exists(quicksavePath))
+            {
+                // EndPlay did not archive the quicksave, so the old main save
+                // and resumable adventure are still the authoritative pair.
+                File.Delete(preparedPath);
+                return PreparedSaveRecovery.DiscardedForQuicksave;
+            }
+
+            if (!validate(preparedPath))
+            {
+                string rejectedPath = preparedPath + ".corrupt";
+                DeleteIfExists(rejectedPath);
+                File.Move(preparedPath, rejectedPath);
+                return PreparedSaveRecovery.Rejected;
+            }
+
+            Commit(preparedPath, destinationPath, backupPath);
+            return PreparedSaveRecovery.Committed;
+        }
+
+        internal static void Discard(string preparedPath)
+        {
+            DeleteIfExists(preparedPath);
+            DeleteIfExists(preparedPath + ".tmp");
+        }
+
+        private static void DeleteIfExists(string path)
+        {
+            if (!String.IsNullOrEmpty(path) && File.Exists(path))
+                File.Delete(path);
+        }
+    }
+}
