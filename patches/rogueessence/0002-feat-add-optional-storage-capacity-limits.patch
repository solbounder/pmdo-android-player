         /// <summary>
         /// Takes all items in the player team's bag and equipped items, and deposits them in storage.
         /// </summary>
-        public void DepositAll()
+        /// <param name="maxUnits">Maximum stored item units, or -1 for unlimited.</param>
+        /// <returns>True if every item was deposited; false if the deposit would exceed the limit.</returns>
+        public bool DepositAll(int maxUnits = -1)
         {
+            if (maxUnits < -1)
+                throw new ArgumentOutOfRangeException(nameof(maxUnits));
             List<InvItem> items = new List<InvItem>();
             int item_count = DataManager.Instance.Save.ActiveTeam.GetInvCount();
 
@@ -1247,6 +1251,16 @@ namespace RogueEssence.Script
                 items.Add(item);
             };
 
+            int depositUnits = 0;
+            foreach (InvItem item in items)
+            {
+                ItemData entry = DataManager.Instance.GetItem(item.ID);
+                depositUnits += entry.UsageType == ItemData.UseType.Box ? 1 :
+                    (entry.MaxStack > 1 ? item.Amount : 1);
+            }
+            if (maxUnits >= 0 && GetPlayerStorageCount() + depositUnits > maxUnits)
+                return false;
+
             // Store all items in the inventory.
             DataManager.Instance.Save.ActiveTeam.StoreItems(items);
 
