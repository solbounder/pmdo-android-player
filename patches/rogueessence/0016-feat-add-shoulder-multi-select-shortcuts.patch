--- /dev/null
+++ b/RogueEssence/Menu/MultiSelectInput.cs
@@ -0,0 +1,26 @@
+namespace RogueEssence.Menu
+{
+    public static class MultiSelectInput
+    {
+        public static bool ShoulderPressed(bool configured, bool leftShoulderPressed, bool rightShoulderPressed,
+            bool leftTriggerPressed, bool rightTriggerPressed)
+        {
+            return configured || leftShoulderPressed || rightShoulderPressed || leftTriggerPressed || rightTriggerPressed;
+        }
+
+        public static bool SelectAllChord(bool leftShoulderDown, bool leftTriggerDown,
+            bool rightShoulderDown, bool rightTriggerDown, bool leftShoulderPressed,
+            bool leftTriggerPressed, bool rightShoulderPressed, bool rightTriggerPressed)
+        {
+            bool leftDown = leftShoulderDown || leftTriggerDown;
+            bool rightDown = rightShoulderDown || rightTriggerDown;
+            bool shoulderPressed = leftShoulderPressed || leftTriggerPressed || rightShoulderPressed || rightTriggerPressed;
+            return leftDown && rightDown && shoulderPressed;
+        }
+
+        public static bool CanSelectChoice(bool enabled, bool selected, int selectedTotal, int maxExclusive)
+        {
+            return enabled && !selected && selectedTotal < maxExclusive - 1;
+        }
+    }
+}
diff --git a/RogueEssence/Menu/SingleStripMenu.cs b/RogueEssence/Menu/SingleStripMenu.cs
