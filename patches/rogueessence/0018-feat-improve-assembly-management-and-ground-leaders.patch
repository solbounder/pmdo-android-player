+        /// <summary>
+        /// Displays the assembly with optional localized search/filter controls
+        /// and a quest-defined reward for a confirmed release.
+        /// </summary>
+        public void AssemblyMenu(LuaTable options)
+        {
+            try
+            {
+                AssemblyMenuOptions config = new AssemblyMenuOptions();
+                if (options != null)
+                {
+                    config.SearchLabel = LuaString(options, "SearchLabel", config.SearchLabel);
+                    config.ClearSearchLabel = LuaString(options, "ClearSearchLabel", config.ClearSearchLabel);
+                    config.FavoritesOnlyLabel = LuaString(options, "FavoritesOnlyLabel", config.FavoritesOnlyLabel);
+                    config.ShowAllLabel = LuaString(options, "ShowAllLabel", config.ShowAllLabel);
+                    config.SearchTitle = LuaString(options, "SearchTitle", config.SearchTitle);
+                    config.ReleaseRewardMessage = LuaString(options, "ReleaseRewardMessage", "");
+                    object reward = options["ReleaseReward"];
+                    if (reward != null)
+                        config.ReleaseReward = Math.Max(0, Convert.ToInt32(reward));
+                }
+                m_choiceresult = false;
+                m_curchoice = new AssemblyMenu(MenuLabel.ASSEMBLY_MENU, 0,
+                    () => { m_choiceresult = true; },
+                    RogueEssence.Menu.AssemblyMenu.AssemblySortMode.Recent,
+                    "", false, config);
+            }
+            catch (Exception e)
+            {
+                DiagManager.Instance.LogError(new Exception(String.Format(
+                    "ScriptUI.AssemblyMenu(options): Encountered exception."), e),
+                    DiagManager.Instance.DevMode);
+            }
+        }
+
+        private static string LuaString(LuaTable options, string key, string fallback)
+        {
+            object value = options[key];
+            return value == null ? fallback : value.ToString();
+        }
+
